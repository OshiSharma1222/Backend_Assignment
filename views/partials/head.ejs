<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <header class="shell nav-wrap">
      <a class="brand" href="/">FairPlay Impact</a>
      <nav class="nav-links">
        <a href="/charities">Charities</a>
        <% if (user) { %>
          <a href="/dashboard">Dashboard</a>
          <% if (user.role === 'admin') { %><a href="/admin">Admin</a><% } %>
          <form action="/logout" method="post"><button class="ghost">Logout</button></form>
        <% } else { %>
          <a href="/login">Login</a>
          <a class="btn" href="/register">Join Now</a>
        <% } %>
      </nav>
    </header>
    <main class="shell">
