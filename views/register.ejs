<%- include('partials/head', { title, user }) %>
<section class="auth-wrap card">
  <h1>Create account</h1>
  <% if (error) { %><p class="error"><%= error %></p><% } %>
  <form method="post" action="/register">
    <label>Full Name</label>
    <input type="text" name="fullName" required />
    <label>Email</label>
    <input type="email" name="email" required />
    <label>Password</label>
    <input type="password" name="password" minlength="6" required />
    <label>Choose Charity</label>
    <select name="charityId" required>
      <% charities.forEach(charity => { %>
        <option value="<%= charity.id %>"><%= charity.name %></option>
      <% }) %>
    </select>
    <label>Charity Contribution % (min 10)</label>
    <input type="number" min="10" max="100" name="charityPercentage" value="10" required />
    <button class="btn" type="submit">Create Account</button>
  </form>
</section>
<%- include('partials/foot') %>
